# Consumer service configuration

# Where to read observer events from
EVENT_LOG=state/observer/events.jsonl

# Where to write derived events
DERIVED_EVENT_LOG=state/consumer/events.jsonl

# Floor-2 long-call warning threshold in seconds (default 2700 = 45 min)
FLOOR_2_WARN_THRESHOLD_S=2700

# Telegram Bot API credentials for alerts
# Get bot token from @BotFather on Telegram
# Chat ID is your personal Telegram user ID
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>
TELEGRAM_CHAT_ID=<your_telegram_chat_id>
