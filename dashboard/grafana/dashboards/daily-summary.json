{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Daily heating summary and floor-2 anomaly history",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3600 }, { "color": "red", "value": 7200 }]
          },
          "min": 0
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "zone_runtime_today_seconds",
          "legendFormat": "{{floor}}",
          "refId": "A"
        }
      ],
      "title": "Total Zone Runtime Today",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1200 }, { "color": "red", "value": 1800 }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "heating_session_duration_seconds",
          "legendFormat": "Last session",
          "refId": "A"
        }
      ],
      "title": "Last Heating Session Duration",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }]
          },
          "mappings": [{ "options": { "0": { "text": "None today" } }, "type": "value" }]
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "floor_runtime_anomaly_total",
          "legendFormat": "Floor 2 anomalies",
          "refId": "A"
        }
      ],
      "title": "Floor 2 Runtime Anomalies (cumulative)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "zone_runtime_today_seconds",
          "legendFormat": "{{floor}}",
          "refId": "A"
        }
      ],
      "title": "Zone Runtime Today (cumulative, all floors)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "heating_session_duration_seconds",
          "legendFormat": "Session duration",
          "refId": "A"
        }
      ],
      "title": "Heating Session Duration History",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "min": 0
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 21 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "floor_runtime_anomaly_total",
          "legendFormat": "Anomaly count (cumulative)",
          "refId": "A"
        }
      ],
      "title": "Floor 2 Anomaly History (cumulative counter)",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["homeops", "summary", "anomaly"],
  "templating": {
    "list": [
      { "current": {}, "hide": 2, "includeAll": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource" }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "America/New_York",
  "title": "Daily Summary + Anomaly History",
  "uid": "homeops-daily",
  "version": 1
}
