{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "Outdoor temperature vs floor zone runtime \u2014 shows how cold weather drives heating demand",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "arrow-left",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": false,
      "title": "\u2190 HomeOps",
      "tooltip": "Back to homeops.now",
      "type": "link",
      "url": "https://homeops.now"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "outdoor"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              },
              {
                "id": "unit",
                "value": "fahrenheit"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "Outdoor Temp (\u00b0F)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* runtime"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.axisLabel",
                "value": "Zone Runtime"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "outdoor_temperature_fahrenheit{job=\"homeops-consumer\"}",
          "legendFormat": "outdoor",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "zone_runtime_today_seconds{floor=\"floor_3\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_3 runtime",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "zone_runtime_today_seconds{floor=\"floor_2\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_2 runtime",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "zone_runtime_today_seconds{floor=\"floor_1\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_1 runtime",
          "refId": "D"
        }
      ],
      "title": "Outdoor Temp vs Zone Runtime Today",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "outdoor"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              },
              {
                "id": "unit",
                "value": "fahrenheit"
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "unit",
                "value": "fahrenheit"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "last",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "outdoor_temperature_fahrenheit{job=\"homeops-consumer\"}",
          "legendFormat": "outdoor",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "floor_temperature_fahrenheit{floor=\"floor_3\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_3",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "floor_temperature_fahrenheit{floor=\"floor_2\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_2",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "floor_temperature_fahrenheit{floor=\"floor_1\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_1",
          "refId": "D"
        }
      ],
      "title": "Outdoor vs Indoor Temperatures (historical)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "min": 0
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "increase(zone_runtime_today_seconds[1h]){floor=\"floor_3\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_3 runtime (1h increase)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "increase(zone_runtime_today_seconds[1h]){floor=\"floor_2\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_2 runtime (1h increase)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "increase(zone_runtime_today_seconds[1h]){floor=\"floor_1\", job=\"homeops-consumer\"}",
          "legendFormat": "floor_1 runtime (1h increase)",
          "refId": "C"
        }
      ],
      "title": "Hourly Runtime Increase per Floor",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": [
    "homeops",
    "correlation"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "America/New_York",
  "title": "Outdoor Temp + Runtime Correlation",
  "uid": "homeops-correlation",
  "version": 1
}
