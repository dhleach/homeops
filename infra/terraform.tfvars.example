# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is gitignored — never commit real values.

aws_region        = "us-east-1"
domain            = "homeops.now"
environment       = "production"
tailscale_ip      = "100.115.21.72"
ec2_instance_type = "t4g.micro"
ebs_volume_size_gb = 20

# Your SSH public key — paste the contents of ~/.ssh/id_ed25519.pub
# or whichever key you want for EC2 access
ssh_public_key = "ssh-ed25519 AAAA... your-key-here"
